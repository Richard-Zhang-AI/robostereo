{
  "name": "ac_reason_embeddings_rectified_flow_2b_256_320_xyz",
  "env": {
    "IMAGINAIRE_OUTPUT_ROOT": "/workspace/imaginaire-output",
    "CUDA_VISIBLE_DEVICES": "7"
  },
  "opts": [
    "experiment=ac_reason_embeddings_rectified_flow_2b_256_320",
    "job.name=bridge_XYZ",
    "~dataloader_train.dataloaders",
    "video_source=geometry",
    "optimizer.lr=3.0517578125e-05",
    "optimizer.weight_decay=0.1",
    "scheduler.warm_up_steps=[1000]",
    "scheduler.cycle_lengths=[10000000000000]",
    "scheduler.f_start=[1.0e-06]",
    "scheduler.f_max=[1.0]",
    "scheduler.f_min=[1.0]",
    "trainer.max_iter=400000",
    "trainer.logging_iter=10",
    "trainer.validation_iter=100",
    "trainer.run_validation=false",
    "ckpt_type=local_pt",
    "checkpoint.save_iter=2000",
    "checkpoint.save_path=checkpoints_files/bridge_action_condtitioned/checkpoints-XYZ/train",
    "dataloader_train.batch_size=2",
    "checkpoint.load_path=checkpoints_files/bridge_action_condtitioned/checkpoints-XYZ/model_ema_converted.pt",
    "checkpoint.load_training_state=false",
    "dataloader_train.dataset.video_path=datasets/bridge_128",
    "dataloader_train.dataset.train_annotation_path=datasets/bridge/annotation/train",
    "dataloader_train.dataset.val_annotation_path=datasets/bridge/annotation/val",
    "dataloader_train.dataset.test_annotation_path=datasets/bridge/annotation/test",
    "dataloader_train.sampler.dataset.video_path=datasets/bridge_128",
    "dataloader_train.sampler.dataset.train_annotation_path=datasets/bridge/annotation/train",
    "dataloader_train.sampler.dataset.val_annotation_path=datasets/bridge/annotation/val",
    "dataloader_train.sampler.dataset.test_annotation_path=datasets/bridge/annotation/test",
    "dataloader_val.dataset.video_path=datasets/bridge",
    "dataloader_val.dataset.train_annotation_path=datasets/bridge/annotation/train",
    "dataloader_val.dataset.val_annotation_path=datasets/bridge/annotation/val",
    "dataloader_val.dataset.test_annotation_path=datasets/bridge/annotation/test",
    "dataloader_val.sampler.dataset.video_path=datasets/bridge_128",
    "dataloader_val.sampler.dataset.train_annotation_path=datasets/bridge/annotation/train",
    "dataloader_val.sampler.dataset.val_annotation_path=datasets/bridge/annotation/val",
    "dataloader_val.sampler.dataset.test_annotation_path=datasets/bridge/annotation/test"
  ]
}
