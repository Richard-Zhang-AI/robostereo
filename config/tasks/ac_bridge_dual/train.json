{
  "name": "ac_reason_embeddings_rectified_flow_2b_256_320_dual",
  "env": {
    "IMAGINAIRE_OUTPUT_ROOT": "/workspace/imaginaire-output",
    "CUDA_VISIBLE_DEVICES": "7"
  },
  "opts": [
    "experiment=ac_reason_embeddings_rectified_flow_2b_256_320_dual",
    "job.name=bridge_dual",
    "data_root=/workspace/datasets/bridge",
    "~dataloader_train.dataloaders",
    "optimizer.lr=3.0517578125e-06",
    "optimizer.weight_decay=0.1",
    "scheduler.warm_up_steps=[1000]",
    "scheduler.cycle_lengths=[10000000000000]",
    "scheduler.f_start=[1.0e-06]",
    "scheduler.f_max=[1.0]",
    "scheduler.f_min=[1.0]",
    "trainer.max_iter=400000",
    "trainer.logging_iter=10",
    "trainer.validation_iter=100",
    "trainer.run_validation=false",
    "ckpt_type=local_pt",
    "checkpoint.save_iter=1000",
    "checkpoint.save_path=checkpoints_files/bridge_action_conditioned/train_dual",
    "model.config.rgb_loss_weight=1.0",
    "model.config.xyz_loss_weight=0.36",
    "model.config.cross_attn_interval=2",
    "model.config.cross_attn_warmup_iters=5000",
    "model.config.cross_attn_dropout=0.1",
    "model.config.cross_attn_weight=1.0",
    "dataloader_train.batch_size=4",
    "model.config.fsdp_shard_size=1",
    "checkpoint.resume_from_checkpoint=false",
    "model.config.rgb_init_checkpoint_path=/workspace/checkpoints_files/bridge_action_conditioned/checkpoints-RGB/model_ema_converted.pt",
    "model.config.xyz_init_checkpoint_path=/workspace/checkpoints_files/bridge_action_conditioned/checkpoints-XYZ/model_ema_converted.pt",
    "dataloader_train.dataset.video_path=/workspace/datasets/bridge",
    "dataloader_train.dataset.video_size=[256, 320]",
    "dataloader_train.dataset.fps_downsample_ratio=1",
    "dataloader_train.dataset.geometry_min=-0.8",
    "dataloader_train.dataset.geometry_max=1.6",
    "dataloader_train.dataset.train_annotation_path=/workspace/datasets/bridge/annotation/train",
    "dataloader_train.dataset.val_annotation_path=/workspace/datasets/bridge/annotation/val",
    "dataloader_train.dataset.test_annotation_path=/workspace/datasets/bridge/annotation/test",
    "dataloader_val.dataset.video_path=/workspace/datasets/bridge",
    "dataloader_val.dataset.video_size=[256, 320]",
    "dataloader_val.dataset.fps_downsample_ratio=1",
    "dataloader_val.dataset.geometry_min=-0.8",
    "dataloader_val.dataset.geometry_max=1.6",
    "dataloader_val.dataset.train_annotation_path=/workspace/datasets/bridge/annotation/train",
    "dataloader_val.dataset.val_annotation_path=/workspace/datasets/bridge/annotation/val",
    "dataloader_val.dataset.test_annotation_path=/workspace/datasets/bridge/annotation/test"
  ]
}
